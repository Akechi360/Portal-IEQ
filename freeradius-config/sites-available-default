server default {
    listen {
        type = auth
        ipaddr = *
        port = 0
    }
    listen {
        type = acct
        ipaddr = *
        port = 0
    }

    authorize {
        rest
        if (ok) {
            update control {
                Auth-Type := rest
            }
        }
    }

    authenticate {
        Auth-Type rest {
            rest
        }
    }
}
