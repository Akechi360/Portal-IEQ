# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_APP_NAME="Portal WiFi Clinica IEQ"

# ─── Ruijie Cloud LATAM ───────────────────────────────────────────────────────
RUIJIE_CLOUD_URL="https://cloud-la.ruijienetworks.com"
RUIJIE_APP_ID="tu-app-id-de-ruijie"
RUIJIE_SECRET="tu-secret-de-ruijie"
RUIJIE_GROUP_ID="tu-group-id"

# ─── Base de datos (Supabase Self-Hosted en Coolify) ─────────────────────────
# PgBouncer pooler — para queries normales de la app
DATABASE_URL="postgresql://postgres.<project>:<password>@<host>:6543/postgres?pgbouncer=true&connect_timeout=10"
# Conexión directa — requerida por: prisma migrate deploy
DIRECT_URL="postgresql://postgres.<project>:<password>@<host>:5432/postgres?connect_timeout=10"

# ─── Autenticación JWT ────────────────────────────────────────────────────────
# OBLIGATORIA. Sin esto la app NO puede firmar sesiones (no hay fallback).
# Generar con: openssl rand -hex 32
JWT_SECRET="reemplazar-con-clave-aleatoria-de-64-chars"

# ─── Setup inicial de admins (/api/admin/setup) ───────────────────────────────
# Secreto para autorizar el seed inicial (sin fallback). Generar: openssl rand -hex 32
SETUP_SECRET="reemplazar-con-clave-aleatoria"
# Contraseñas iniciales de los admins que crea el setup (solo se usan una vez;
# luego viven hasheadas en la DB). Mantener fuera del código.
SETUP_ADMIN_PASSWORD="clave-fuerte-del-superadmin"
SETUP_OPERADOR_PASSWORD="clave-fuerte-del-operador"

# ─── Webhooks ─────────────────────────────────────────────────────────────────
# Generar con: openssl rand -hex 32
WEBHOOK_CLINIC_SECRET="reemplazar-con-clave-aleatoria"

# ─── RADIUS (protección del endpoint /api/radius/verify) ──────────────────────
# Opcional pero recomendado en producción: si se define, FreeRADIUS debe enviar
# el mismo valor (?k=<secreto> en la uri del módulo rest). Evita que cualquiera
# enumere correos/vouchers válidos. Generar: openssl rand -hex 32
RADIUS_SHARED_SECRET=""

# ─── Mantenimiento / Cron ─────────────────────────────────────────────────────
# Secreto para /api/cron/purge (Coolify Scheduled Task). Generar con: openssl rand -hex 32
CRON_SECRET="reemplazar-con-clave-aleatoria"

# ─── Opcional ─────────────────────────────────────────────────────────────────
ACCESS_TOKEN_BYTES=16
DEFAULT_BCRYPT_ROUNDS=10
