generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}


// ─── CREDENCIALES (Paciente / Tránsito) ───────────────────
model Credential {
  id           String           @id @default(cuid())
  voucherCode  String           @unique
  tipo         CredentialType   // PACIENTE | TRANSITO
  nombre       String
  habitacion   String?
  maxDevices   Int              @default(1)
  diasEstancia Int?             // solo Paciente
  expireAt     DateTime?
  issuerId     String           // ID del admin/operador que lo emitió
  issuer       Admin            @relation("AdminToCredentials", fields: [issuerId], references: [id])
  status       CredentialStatus @default(ACTIVE)
  sessions     Session[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

// ─── MÉDICOS ───────────────────────────────────────────────
model Doctor {
  id           String       @id @default(cuid())
  nombre       String
  especialidad String?
  email        String       @unique
  telefono     String?
  voucherCode  String?      @unique  // voucher permanente en Ruijie
  status       DoctorStatus @default(PENDING)
  sessions     Session[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

// ─── SESIONES WiFi ────────────────────────────────────────
model Session {
  id           String      @id @default(cuid())
  mac          String
  ip           String?
  ssid         String?
  credentialId String?
  doctorId     String?
  startedAt    DateTime    @default(now())
  endedAt      DateTime?
  dataDownMB   Float?
  dataUpMB     Float?
  credential   Credential? @relation(fields: [credentialId], references: [id])
  doctor       Doctor?     @relation(fields: [doctorId], references: [id])

  @@index([mac])
  @@index([startedAt])
  @@index([credentialId])
  @@index([doctorId])
}

// ─── LOGS DE ACCESO ───────────────────────────────────────
model AccessLog {
  id        String    @id @default(cuid())
  event     LogEvent
  actor     String
  mac       String?
  ip        String?
  ssid      String?
  detail    String?
  createdAt DateTime  @default(now())

  @@index([createdAt])
  @@index([event])
  @@index([mac])
}

// ─── ADMINISTRADORES del panel ────────────────────────────
model Admin {
  id                String       @id @default(cuid())
  nombre            String
  username          String       @unique
  email             String       @unique
  passwordHash      String
  role              AdminRole    @default(OPERADOR)
  status            AdminStatus  @default(ACTIVE)
  lastLoginAt       DateTime?
  createdAt         DateTime     @default(now())
  credentialsIssued Credential[] @relation("AdminToCredentials")
}

// ─── CONFIGURACIÓN del portal público ────────────────────
model PortalConfig {
  id            String   @id @default(cuid())
  portalName    String   @default("Portal IEQ")
  slogan        String?
  logoUrl       String?
  bgUrl         String?
  primaryColor  String   @default("#0EA5E9")
  fontFamily    String   @default("Inter")
  loginTitle    String   @default("Acceso WiFi")
  loginButton   String   @default("Conectarme")
  successMsg    String   @default("¡Acceso concedido!")
  errorMsg      String   @default("Código inválido o expirado.")
  updatedAt     DateTime @updatedAt
}

// ─── CONFIGURACIÓN DEL SISTEMA (Toggles internos) ────────
model SystemConfig {
  key         String   @id
  value       String   // Se almacena como string. La capa de acceso debe hacer JSON.parse/stringify
  description String?
  updatedAt   DateTime @updatedAt
}

// ─── ENUMS ────────────────────────────────────────────────
enum CredentialType {
  PACIENTE
  TRANSITO
}

enum CredentialStatus {
  ACTIVE
  EXPIRED
  BLOCKED
}

enum DoctorStatus {
  PENDING
  ACTIVE
  INACTIVE
}

enum LogEvent {
  AUTH_SUCCESS
  AUTH_FAIL
  BLOCKED
  DISCONNECTED
  NEW_SESSION
  LIMIT_REACHED
  DOCTOR_APPROVED
  DOCTOR_REJECTED
}

enum AdminRole {
  SUPERADMIN
  ADMIN
  OPERADOR
}

enum AdminStatus {
  ACTIVE
  INACTIVE
}
