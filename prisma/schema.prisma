generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Credential {
  id           String           @id @default(cuid())
  voucherCode  String           @unique
  tipo         CredentialType
  nombre       String
  habitacion   String?
  maxDevices   Int              @default(1)
  diasEstancia Int?
  expireAt     DateTime?
  issuerId     String
  status       CredentialStatus @default(ACTIVE)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  issuer         Admin           @relation("AdminToCredentials", fields: [issuerId], references: [id])
  sessions       Session[]
  deviceBindings DeviceBinding[]
}

model DeviceBinding {
  id           String     @id @default(cuid())
  credentialId String
  mac          String
  boundAt      DateTime   @default(now())
  credential   Credential @relation(fields: [credentialId], references: [id], onDelete: Cascade)

  @@unique([credentialId, mac])
  @@index([credentialId])
}

model Doctor {
  id           String       @id @default(cuid())
  nombre       String
  especialidad String?
  email        String       @unique
  telefono     String?
  voucherCode  String?      @unique
  status       DoctorStatus @default(PENDING)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  sessions       Session[]
  deviceBindings DoctorDeviceBinding[]
}

model DoctorDeviceBinding {
  id        String   @id @default(cuid())
  doctorId  String
  mac       String
  boundAt   DateTime @default(now())
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, mac])
  @@index([doctorId])
}

model StaffUser {
  id        String      @id @default(cuid())
  email     String      @unique
  nombre    String?
  status    StaffStatus @default(ACTIVE)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  sessions  Session[]
}

model Session {
  id            String            @id @default(cuid())
  acctSessionId String?           @unique
  mac           String
  ip            String?
  ssid          String?
  credentialId  String?
  doctorId      String?
  startedAt     DateTime          @default(now())
  endedAt       DateTime?
  lastSeenAt    DateTime?
  dataDownMB    Float?
  dataUpMB      Float?
  accessType    SessionAccessType
  staffUserId   String?
  credential    Credential?       @relation(fields: [credentialId], references: [id])
  doctor        Doctor?           @relation(fields: [doctorId], references: [id])
  staffUser     StaffUser?        @relation(fields: [staffUserId], references: [id])

  @@index([mac])
  @@index([startedAt])
  @@index([credentialId])
  @@index([doctorId])
  @@index([staffUserId])
}

model AccessLog {
  id        String   @id @default(cuid())
  event     LogEvent
  actor     String
  mac       String?
  ip        String?
  ssid      String?
  detail    String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([event])
  @@index([mac])
}

model Admin {
  id                String       @id @default(cuid())
  nombre            String
  username          String       @unique
  email             String       @unique
  passwordHash      String
  role              AdminRole    @default(OPERADOR)
  status            AdminStatus  @default(ACTIVE)
  lastLoginAt       DateTime?
  createdAt         DateTime     @default(now())
  credentialsIssued Credential[] @relation("AdminToCredentials")
}

model PortalConfig {
  id           String   @id @default(cuid())
  portalName   String   @default("Portal IEQ")
  slogan       String?
  logoUrl      String?
  bgUrl        String?
  primaryColor String   @default("#0EA5E9")
  fontFamily   String   @default("Inter")
  loginTitle   String   @default("Acceso WiFi")
  loginButton  String   @default("Conectarme")
  successMsg   String   @default("¡Acceso concedido!")
  errorMsg     String   @default("Código inválido o expirado.")
  updatedAt    DateTime @updatedAt
}

model SystemConfig {
  key         String   @id
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

enum CredentialType {
  PACIENTE
  TRANSITO
}

enum CredentialStatus {
  ACTIVE
  EXPIRED
  BLOCKED
}

enum DoctorStatus {
  PENDING
  ACTIVE
  INACTIVE
}

enum StaffStatus {
  ACTIVE
  INACTIVE
}

enum SessionAccessType {
  GUEST
  DOCTOR
  STAFF
}

enum LogEvent {
  AUTH_SUCCESS
  AUTH_FAIL
  BLOCKED
  DISCONNECTED
  NEW_SESSION
  LIMIT_REACHED
  DOCTOR_APPROVED
  DOCTOR_REJECTED
}

enum AdminRole {
  SUPERADMIN
  ADMIN
  OPERADOR
}

enum AdminStatus {
  ACTIVE
  INACTIVE
}
